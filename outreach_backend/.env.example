# Server
PORT=5000

# PostgreSQL (Supabase) — pooled URL for the app, direct URL for Prisma migrations
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Supabase (resume storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash) — BullMQ queue + rate limiting
REDIS_URL=rediss://default:password@host:6379

# LLMs — Gemini is primary, OpenAI is the optional fallback
GEMINI_API_KEY=
OPENAI_API_KEY=

# Clerk (auth) — webhook secret verifies Svix-signed Clerk webhooks
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Google OAuth (Gmail API send/sync)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost:5173/sso-callback
