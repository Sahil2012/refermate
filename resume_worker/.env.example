# Gemini — resume extraction (structured output)
GEMINI_API_KEY=

# PostgreSQL (Supabase) — same database as outreach_backend
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Supabase Storage — downloads resume PDFs from the "resumes" bucket
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash) — consumes the "resume-processing" BullMQ queue
REDIS_URL=rediss://default:password@host:6379
